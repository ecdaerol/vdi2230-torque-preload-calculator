{
  "name": "@ecdaerol/torque-calculator",
  "version": "0.1.0",
  "type": "module",
  "description": "VDI 2230 bolt torque and preload calculator",
  "main": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "types": "./dist/lib/index.d.ts"
    },
    "./styles.css": "./dist/lib/style.css"
  },
  "files": [
    "dist/lib"
  ],
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "build:lib": "vite build --config vite.lib.config.ts && tsc -p tsconfig.lib.json",
    "build:desktop": "npm run build && npx electron-builder --config electron-builder.yml",
    "prepublishOnly": "npm run build:lib"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.0.4",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ecdaerol/vdi2230-torque-preload-calculator"
  },
  "author": "Ecda Erol",
  "license": "MIT"
}

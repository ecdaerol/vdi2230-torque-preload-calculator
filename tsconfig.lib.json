{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist/lib",
    "moduleResolution": "node",
    "allowImportingTsExtensions": false
  },
  "include": [
    "src/lib/index.ts",
    "src/calc/**/*.ts",
    "src/domain/**/*.ts",
    "src/data/**/*.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx"]
}
